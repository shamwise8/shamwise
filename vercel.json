{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/links", "destination": "/links.html" },
    { "source": "/linkx", "destination": "/linkx.html" },
    { "source": "/team1kickoff", "destination": "/Team1KickOff/index.html" },
    { "source": "/team1kickoff/", "destination": "/Team1KickOff/index.html" },
    { "source": "/Team1Kickoff", "destination": "/Team1KickOff/index.html" },
    { "source": "/tu", "destination": "/TU/index.html" },
    { "source": "/tu/", "destination": "/TU/index.html" },
    { "source": "/Tu", "destination": "/TU/index.html" }
  ]
}
